---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import JobOfferDetailIsland from "@/components/careers/JobOfferDetailIsland";

const { id } = Astro.params;
const url = Astro.url;
---

<Layout
  title={`Career Offer`}
  description={"View career opportunity details and apply."}
>
  <JobOfferDetailIsland id={id!} pathname={url.pathname} client:only="react" />
</Layout>
